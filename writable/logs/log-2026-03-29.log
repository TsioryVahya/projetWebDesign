 1 SYSTEMPATH/Database/BaseConnection.php(910): CodeIgniter\Database\MySQLi\Connection->execute('INSERT INTO `articles` (`titre`, `chapeau`, `corps`, `section`, `image_alt`, `meta_title`, `date_publication`, `slug`, `created_at`, `updated_at`) VALUES (\'Guerre en Iran\', \'<p>Une grande guerre</p>\', \'<h1 id=\\"js-title-live\\" class=\\"title__sirius-live\\">Guerre en Iran : nouvelles frappes isra&eacute;liennes sur T&eacute;h&eacute;ran ; un mort en Isra&euml;l apr&egrave;s des tirs de missiles de l&rsquo;Iran. Suivez les informations du 21 au 27 mars</h1>\\r\\n<p><img src=\\"../uploads/articles/1774787766_b267d19888dfe4c77560.jpeg\\" alt=\\"\\" width=\\"960\\" height=\\"432\\"></p>\\r\\n<p>&nbsp;</p>\\r\\n<h2 class=\\"post__live-container--title post__space-node\\">L&rsquo;Iran rapporte une nouvelle attaque contre une centrale nucl&eacute;aire</h2>\\r\\n<div class=\\"post__live-container--answer\\">\\r\\n<p class=\\"post__live-container--answer-text post__space-node\\">L&rsquo;Iran a d&eacute;nonc&eacute; une nouvelle attaque contre sa centrale nucl&eacute;aire de Bouchehr, dans le sud du pays, la troisi&egrave;me en dix jours.</p>\\r\\n</div>\\r\\n<div class=\\"post__live-container--answer\\">\\r\\n<p class=\\"post__live-container--answer-text post__space-node\\"><em>&laquo;&nbsp;Aucun dommage sur le r&eacute;acteur actif et aucune &eacute;mission de radiation n&rsquo;ont &eacute;t&eacute; signal&eacute;s, et les conditions de la centrale sont normales&nbsp;&raquo;</em>, a &eacute;crit sur X l&rsquo;Agence internationale de l&rsquo;&eacute;nergie atomique (AIEA), en citant des responsables iraniens.</p>\\r\\n</div>\\r\\n<div class=\\"post__live-container--answer\\">\\r\\n<p class=\\"post__live-container--answer-text post__space-node\\">Seule centrale nucl&eacute;aire op&eacute;rationnelle d&rsquo;Iran, Bouchehr avait d&eacute;j&agrave; &eacute;t&eacute; attaqu&eacute;e les 17&nbsp;et 24&nbsp;mars, sans que des d&eacute;g&acirc;ts ne soient rapport&eacute;s. Apr&egrave;s cette deuxi&egrave;me frappe, la Russie avait annonc&eacute; l&rsquo;&eacute;vacuation de ses personnels travaillant dans cette centrale de technologie russe, entr&eacute;e en service au d&eacute;but des ann&eacute;es 2010&nbsp;et comportant deux r&eacute;acteurs.</p>\\r\\n</div>\\r\\n<div class=\\"post__live-container--answer\\">\\r\\n<p class=\\"post__live-container--answer-text post__space-node\\">Bouchehr a une capacit&eacute; de production de 1&nbsp;000&nbsp;m&eacute;gawatts. Avant le d&eacute;but du conflit, la Russie &eacute;tait en train de construire deux nouvelles tranches sur le site.</p>\\r\\n</div>\\r\\n<div class=\\"post__live-container--answer\\">\\r\\n<p class=\\"post__live-container--answer-text post__space-node\\">Plus t&ocirc;t vendredi, Isra&euml;l avait annonc&eacute; avoir frapp&eacute; deux sites nucl&eacute;aires dans le centre de l&rsquo;Iran, le r&eacute;acteur &agrave; eau lourde d&rsquo;Arak et une usine de traitement d&rsquo;uranium dans la province de Yazd.</p>\\r\\n</div>\', \'International\', \'Guerre en Iran\', \'Guerre en Iran\', \'2026-03-29T12:34\', \'guerre-en-iran\', \'2026-03-29 12:36:50\', \'2026-03-29 12:36:50\')')
